generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement()) 
  username String @unique
  name String
  surname String
  password String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  passwordChangedAt DateTime
  refreshToken String?
  cafes Cafe[]
}

model Cafe {
  id Int @id @default(autoincrement()) 
  ownerId Int
  user User @relation(fields: [ownerId], references: [id])
  description String
  name String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  points CafePoint[]
}

model CafePoint {
  id Int @id @default(autoincrement()) 
  cafeId Int
  cafe Cafe @relation(fields: [cafeId], references: [id])
  yandexId String @unique
  name String
  address String
  lat Float?
  lng Float?
  workHours String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  reviews Review[]
}

model Review {
  id Int @id @default(autoincrement()) 
  cafePointId Int
  cafePoint CafePoint @relation(fields: [cafePointId], references: [id])
  usernameOfReviewer String
  text String
  rating Int
  createdAt DateTime @default(now())
  aiAnswer String?
  status String @default("pending")
}