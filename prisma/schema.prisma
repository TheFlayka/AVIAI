generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement()) 
  username String @unique
  name String
  surname String
  password String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  passwordChangedAt DateTime
  refreshToken String?
  companies Company[]
}

enum ParsingStatus {
  IDLE        
  PROCESSING  
  SUCCESS     
  FAILED      
}

model Company {
  id Int @id @default(autoincrement()) 
  ownerId Int
  user User @relation(fields: [ownerId], references: [id])
  description String
  name String
  yandexMapsUrl String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  statusParsingMaps ParsingStatus @default(IDLE)
  points CompanyPoint[]
}

model CompanyPoint {
  id Int @id @default(autoincrement()) 
  companyId Int
  company Company @relation(fields: [companyId], references: [id])
  yandexId String @unique
  name String
  address String
  lat Float?
  lng Float?
  workHours String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  reviews Review[]
}

model Review {
  id Int @id @default(autoincrement()) 
  companyPointId Int
  companyPoint CompanyPoint @relation(fields: [companyPointId], references: [id])
  usernameOfReviewer String
  text String
  rating Int
  createdAt DateTime @default(now())
  aiAnswer String?
  status String @default("pending")
}