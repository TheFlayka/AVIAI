generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Simple User Model Schema
model User {
  id Int @id @default(autoincrement()) 
  username String @unique
  name String
  surname String
  password String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  passwordChangedAt DateTime
  refreshToken String?
  companies Company[]
}

// Company model with status of parsing maps
enum ParsingStatus {
  IDLE        
  PROCESSING  
  SUCCESS     
  FAILED      
}

model Company {
  id Int @id @default(autoincrement()) 
  ownerId Int
  user User @relation(fields: [ownerId], references: [id])
  name String
  yandexMapsUrl String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  statusParsingMaps ParsingStatus @default(IDLE)
  points CompanyPoint[]
}

// Company Point model with status of parsing reviews page
enum ParsingReviewsStatus {     
  IDLE
  PROCESSING  
  SUCCESS     
  FAILED      
}

model CompanyPoint {
  id Int @id @default(autoincrement()) 
  companyId Int
  company Company @relation(fields: [companyId], references: [id])
  yandexId String @unique
  name String
  address String
  createdAt DateTime @default(now())
  deletedAt DateTime?
  lastParseAt DateTime?
  statusParsingReviews ParsingReviewsStatus @default(IDLE)
  reviews Review[]
}

// Review model with status of writing answer for
enum ReviewStatus {
  WAITING  
  SUCCESS     
  FAILED      
}

model Review {
  id Int @id @default(autoincrement()) 
  companyPointId Int
  companyPoint CompanyPoint @relation(fields: [companyPointId], references: [id])
  reviewerName String
  content String
  rating Int
  createdAt DateTime
  aiAnswer String?
  statusWritingAnswer ReviewStatus @default(WAITING)
}